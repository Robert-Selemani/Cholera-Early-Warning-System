# Streamlit Secrets Configuration Template
# Copy this file to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to version control

# DHIS2 Configuration (Optional)
[dhis2]
server_url = "https://your-dhis2-instance.org"
username = "your_username"
password = "your_password"
api_version = "39"

# API Keys (if needed)
[api_keys]
climate_api_key = "your_climate_api_key"
google_earth_engine = "your_gee_credentials"

# Database Configuration (Optional)
[database]
connection_string = "your_database_connection_string"
