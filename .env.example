# Environment Variables for Cholera Early Warning System
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_TYPE=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cholera_ews
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password

# API Keys
COPERNICUS_API_KEY=your_copernicus_key
COPERNICUS_API_UID=your_copernicus_uid
NOAA_API_TOKEN=your_noaa_token

# Notification Services
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=alerts@choleraews.org
EMAIL_TO=recipient1@example.com,recipient2@example.com

# SMS Configuration (Optional)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_secret_key_here_change_in_production

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
DASHBOARD_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/cholera_ews.log

# System Configuration
TIMEZONE=Africa/Harare
MAX_WORKERS=4

# External Services (Optional)
MAPBOX_ACCESS_TOKEN=your_mapbox_token
GOOGLE_MAPS_API_KEY=your_google_maps_key
